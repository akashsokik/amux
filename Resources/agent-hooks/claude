#!/bin/bash
# amux wrapper for claude -- injects hooks when running inside amux

# If not inside amux (no AMUX_PANE_ID), find and exec the real claude
if [ -z "$AMUX_PANE_ID" ] || [ -z "$AMUX_SOCKET_PATH" ]; then
    SELF_DIR="$(cd "$(dirname "$0")" && pwd)"
    REAL_CLAUDE=""
    IFS=: read -ra PATH_DIRS <<< "$PATH"
    for dir in "${PATH_DIRS[@]}"; do
        resolved="$(cd "$dir" 2>/dev/null && pwd)"
        [ "$resolved" = "$SELF_DIR" ] && continue
        if [ -x "$dir/claude" ]; then
            REAL_CLAUDE="$dir/claude"
            break
        fi
    done
    if [ -z "$REAL_CLAUDE" ]; then
        echo "amux: could not find real claude binary" >&2
        exit 1
    fi
    exec "$REAL_CLAUDE" "$@"
fi

# Inside amux -- find real claude (same PATH scan skipping self)
SELF_DIR="$(cd "$(dirname "$0")" && pwd)"
REAL_CLAUDE=""
IFS=: read -ra PATH_DIRS <<< "$PATH"
for dir in "${PATH_DIRS[@]}"; do
    resolved="$(cd "$dir" 2>/dev/null && pwd)"
    [ "$resolved" = "$SELF_DIR" ] && continue
    if [ -x "$dir/claude" ]; then
        REAL_CLAUDE="$dir/claude"
        break
    fi
done
if [ -z "$REAL_CLAUDE" ]; then
    echo "amux: could not find real claude binary" >&2
    exit 1
fi

# Hook helper script (sibling)
HOOK_SCRIPT="$SELF_DIR/amux-agent-hook.sh"

# Build hook settings JSON for Claude Code --settings injection
# Format: EventName -> [matcher groups] -> hooks array (3-level nesting)
HOOK_SETTINGS=$(cat <<ENDJSON
{
  "hooks": {
    "SessionStart": [{"matcher": "", "hooks": [{"type": "command", "command": "$HOOK_SCRIPT session-start", "timeout": 10}]}],
    "Stop": [{"matcher": "", "hooks": [{"type": "command", "command": "$HOOK_SCRIPT stop", "timeout": 10}]}],
    "Notification": [{"matcher": "", "hooks": [{"type": "command", "command": "$HOOK_SCRIPT notification", "timeout": 10}]}],
    "PreToolUse": [{"matcher": "", "hooks": [{"type": "command", "command": "$HOOK_SCRIPT pre-tool-use", "timeout": 10}]}],
    "PostToolUse": [{"matcher": "", "hooks": [{"type": "command", "command": "$HOOK_SCRIPT post-tool-use", "timeout": 10}]}]
  }
}
ENDJSON
)

exec "$REAL_CLAUDE" --settings "$HOOK_SETTINGS" "$@"
